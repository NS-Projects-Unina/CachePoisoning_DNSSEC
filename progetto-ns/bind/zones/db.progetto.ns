$ORIGIN .
$TTL 86400	; 1 day
progetto.ns		IN SOA	ns1.progetto.ns. admin.progetto.ns. (
				8          ; serial
				86400      ; refresh (1 day)
				86400      ; retry (1 day)
				86400      ; expire (1 day)
				86400      ; minimum (1 day)
				)
			NS	ns1.progetto.ns.
$ORIGIN progetto.ns.
$TTL 60	; 1 minute
admin			A	10.10.10.10
$TTL 86400	; 1 day
admin-record		A	10.0.1.100
db			A	192.168.100.10
mail			A	1.2.3.5
ns1			A	172.20.0.53
vpn			A	1.2.3.6
www			A	1.2.3.4
