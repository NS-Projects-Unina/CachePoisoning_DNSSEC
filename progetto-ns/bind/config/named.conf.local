key "tsig-update" {
        algorithm hmac-sha256;
        secret "CxzmZ0nnbzWXnxGjcCuDycgJ6vIplu2Ammo4rEVSO1k=";
};

zone "progetto.ns" {
    type master;
    file "/var/lib/bind/db.progetto.ns"; 
    allow-query { any; };
    
    allow-update { key "tsig-update"; };
    allow-transfer { key "tsig-update"; };
    
    key-directory "/etc/bind/keys";   
    inline-signing yes;               
    dnssec-policy default;             
};
